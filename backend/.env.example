# PropSpace Backend Environment Variables
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env to version control!

# Server Configuration
PORT=5000

# Database Configuration
# Example: mongodb://localhost:27017/propspace
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/propspace
MONGO_URI=

# JWT Configuration
# Use a strong, random secret key (minimum 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
